# Bu dosyayı .env olarak kopyala: cp .env.example .env
# Render'da bunları "Environment" sekmesinden tek tek gireceksin, dosya olarak değil.

# --- Zorunlu ---
TELEGRAM_BOT_TOKEN=

# --- Kalıcı hafıza (Supabase) ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Sohbet AI sağlayıcıları (kullanmadığını boş bırakabilirsin, o buton hata verir) ---
GOOGLE_AI_STUDIO_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
COHERE_API_KEY=
HUGGINGFACE_API_KEY=
AGNES_API_KEY=
# Pollinations key istemiyor, bu yüzden burada yok.

# --- Ses servisleri (ikisinden biri yeterli, ikisi de olursa Deepgram önce denenir) ---
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
# Metni sese çevirme (gTTS) key istemiyor, burada yok.

# --- Görsel/Video servisleri ---
JSON2VIDEO_API_KEY=
# Pollinations, Gemini (Nano Banana) ve Agnes görsel üretimi zaten diğer
# key'leri paylaşıyor, ayrı bir key gerektirmiyor.

# --- Render otomatik ayarlar (dokunma) ---
PORT=10000
